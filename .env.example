# === Hetzner Cloud API ===
# Get token from: console.hetzner.com -> Security -> API Tokens (Read & Write)
HETZNER_API_TOKEN=

# === Hetzner DNS API (optional, enables DNS management tools) ===
# Get token from: dns.hetzner.com -> API Tokens
# If not set, DNS tools will not be available.
HETZNER_DNS_TOKEN=

# === Server Definitions ===
# List your server names (comma-separated). These become the target names in MCP tools.
SERVERS=web

# For each server, define: ID, IP, SSH user, and optional aliases.
# Use uppercase server name as prefix: SERVER_{UPPER_NAME}_{FIELD}
SERVER_WEB_ID=12345678
SERVER_WEB_IP=1.2.3.4
SERVER_WEB_SSH_USER=root
SERVER_WEB_ALIASES=production,prod,live
# SERVER_WEB_SSH_PORT=22

# Example: adding a second server
# SERVERS=web,staging
# SERVER_STAGING_ID=87654321
# SERVER_STAGING_IP=5.6.7.8
# SERVER_STAGING_SSH_USER=root
# SERVER_STAGING_ALIASES=stage,dev

# Default server when no 'server' param is specified in tool calls
DEFAULT_SERVER=web

# === SSH Configuration (required for Layer 2 / SSH tools) ===
# Path to Ed25519 private key. If not set or file doesn't exist, SSH tools will not be registered.
SSH_KEY_PATH=/root/.ssh/id_ed25519
SSH_PORT=22
SSH_TIMEOUT=10

# === MCP Authentication ===
# Three modes:
#   1. No auth:      Leave MCP_API_KEY empty and don't set OAUTH vars.
#                     Secure your server via firewall, VPN, or Cloudflare Access.
#   2. API key:       Set MCP_API_KEY. Clients pass it as ?key=XXX or Authorization: Bearer XXX.
#                     Generate with: openssl rand -hex 32
#   3. API key+OAuth: Set both MCP_API_KEY and OAUTH vars below.
#                     Static key and OAuth tokens are both accepted.
MCP_API_KEY=
MCP_INSTANCE_NAME=hetzner-mcp

# === OAuth 2.1 (optional, for MCP connector flow) ===
# Enable this if you want Claude.ai / Claude Desktop to use OAuth for user authentication.
# Requires an external OAuth 2.1 authorization server with token introspection (RFC 7662).
# When enabled, the MCP validates OAuth access tokens in addition to static API keys.
# Leave all OAUTH_ vars commented out to disable.
# OAUTH_INTROSPECT_URL=https://your-oauth-server.com/introspect
# OAUTH_CLIENT_ID=your-client-id
# OAUTH_CLIENT_SECRET=your-client-secret
# OAUTH_RESOURCE_URL=https://your-mcp-domain.com

# === Rate Limiting (optional) ===
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_STORAGE_DIR=/tmp/hetzner-mcp-ratelimit
