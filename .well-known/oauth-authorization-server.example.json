{
  "issuer": "https://your-mcp-server.example.com",
  "authorization_endpoint": "https://your-oauth-server.example.com/authorize",
  "token_endpoint": "https://your-oauth-server.example.com/token",
  "revocation_endpoint": "https://your-oauth-server.example.com/revoke",
  "introspection_endpoint": "https://your-oauth-server.example.com/introspect",
  "registration_endpoint": "https://your-mcp-server.example.com/register",
  "response_types_supported": ["code"],
  "grant_types_supported": ["authorization_code", "refresh_token"],
  "token_endpoint_auth_methods_supported": ["client_secret_basic", "client_secret_post", "none"],
  "code_challenge_methods_supported": ["S256"],
  "scopes_supported": ["mcp:read", "mcp:write", "mcp:admin"]
}
